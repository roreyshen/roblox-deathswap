      "GameConfig": { "$path": "ReplicatedStorage/Modules/GameConfig.lua" },
      "MapManager":  { "$path": "ReplicatedStorage/Modules/MapManager.lua" },

      "RemoteEvents": {
        "$className": "Folder",
        "SwapPlayers":        { "$className": "RemoteEvent" },
